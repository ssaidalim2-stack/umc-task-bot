# --- Telegram ---
BOT_TOKEN=123456:ABC-yourBotTokenFromBotFather
# Секрет для проверки webhook (придумай любую длинную строку)
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
# ВНИМАНИЕ: service_role key, только на сервере!
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# --- Доступ ---
# Telegram ID первичных админов через запятую (узнать: напиши боту @userinfobot)
